# ─── Discord OAuth (next-auth) ───────────────────────────────────────────────
# Discord Developer Portal → Applications → Coco → OAuth2
# Redirect URL olarak şunu ekleyin: https://coco.vercel.app/api/auth/callback/discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# next-auth için rastgele bir gizli anahtar üretin: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://coco.vercel.app

# ─── Botun Canlı İstatistik Sunucusu ─────────────────────────────────────────
# Discord botunuzun çalıştığı sunucuda küçük bir HTTP endpoint açın
# (örn. Express ile /internal/stats) ve buraya adresini yazın.
# Bu endpoint şu şekilde JSON dönmelidir:
# {
#   "servers": 44, "users": 180286, "channels": 2609, "commandsRun": 1639,
#   "uptimeMs": 123456789, "ping": 87, "threatsBlocked": 3182,
#   "messagesScanned": 92104, "memoryUsedMB": 431.6, "memoryTotalMB": 1024,
#   "shards": [{ "id": 0, "servers": 44, "ping": 87 }]
# }
BOT_STATS_URL=
BOT_STATS_TOKEN=

# ─── Yapay Zekâ Destekli Arama (opsiyonel) ───────────────────────────────────
# Boş bırakılırsa arama otomatik olarak basit metin eşleşmesine düşer.
GEMINI_API_KEY=
